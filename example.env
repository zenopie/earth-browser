# Earth Browser — earthserv environment variables
#
# Set EARTHSERV_PRIVATE_KEY to a base64-encoded Reticulum identity file
# to use a specific .ret address. If not set, a new identity is generated.
#
# Generate one locally:
#   python3 -c "import RNS; i=RNS.Identity(); i.to_file('/tmp/my.id'); print(__import__('base64').b64encode(open('/tmp/my.id','rb').read()).decode())"

EARTHSERV_PRIVATE_KEY=
